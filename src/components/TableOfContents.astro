---
import TocTree from './TocTree.astro';
import { buildTocForest, type Heading } from '../lib/content/tocTree';

interface Props {
  headings: Heading[];
}

// Build tree structure supporting multiple H1s
const tocForest = buildTocForest(Astro.props.headings);
if (tocForest.length === 0) {
  return null;
}
---

<div
  class="w-full lg:sticky lg:self-start"
  data-toc-shell
  style="--toc-sticky-top: calc(var(--site-header-height) + var(--page-space-top, 0px)); --toc-max-height: calc(100dvh - var(--toc-sticky-top) - 1rem); top: var(--toc-sticky-top);"
>
  <aside class="hidden lg:block">
    <div
      class="flex w-full flex-col overflow-hidden rounded-xl border border-zinc-200 bg-neutral-50/80 p-[var(--surface-card-padding)] shadow-md backdrop-blur-sm dark:border-zinc-800 dark:bg-zinc-900/50"
      style="max-height: var(--toc-max-height);"
      data-toc-container
    >
      <div class="space-y-1">
        <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">文章目录</p>
      </div>
      <nav
        aria-label="文章目录"
        class="mt-4 pr-1 lg:min-h-0 lg:flex-1 lg:overflow-y-auto"
        data-toc-scroll
      >
        <ol class="space-y-3 text-sm">
          <TocTree nodes={tocForest} />
        </ol>
      </nav>
    </div>
  </aside>
</div>

<script>
  const tocShell = document.querySelector('[data-toc-shell]') as HTMLElement | null;
  const tocLinks = Array.from(
    tocShell?.querySelectorAll('[data-toc-link]') ?? [],
  ) as HTMLAnchorElement[];

  // Get header offset from CSS variable
  const getHeaderOffset = (): number => {
    const headerHeightStr = getComputedStyle(document.documentElement).getPropertyValue(
      '--site-header-height',
    );
    return parseFloat(headerHeightStr) || 0;
  };

  const getPageTopGap = (): number => {
    const pageGapStr = getComputedStyle(document.documentElement).getPropertyValue(
      '--page-space-top',
    );
    return parseFloat(pageGapStr) || 0;
  };

  const getAnchorOffset = (): number => getHeaderOffset() + getPageTopGap() + 12;

  const initTocEnhancements = () => {
    if (!tocShell || tocLinks.length === 0) return;
    if (tocShell.dataset.initialized === 'true') return;
    tocShell.dataset.initialized = 'true';

    const headings = tocLinks
      .map((link) => document.getElementById(link.dataset.target || ''))
      .filter((el): el is HTMLElement => Boolean(el));

    const applyScrollMargin = () => {
      const anchorOffset = getAnchorOffset();
      headings.forEach((heading) => {
        heading.style.scrollMarginTop = `${anchorOffset}px`;
      });
    };

    const encodedHash = (id: string) => `#${encodeURIComponent(id)}`;
    const decodeHash = (hash: string) => decodeURIComponent(hash.replace(/^#/, ''));

    const setActive = (id: string | null) => {
      tocLinks.forEach((link) => {
        const isActive = link.dataset.target === id;
        link.dataset.active = isActive ? 'true' : 'false';
        link.setAttribute('aria-current', isActive ? 'true' : 'false');
      });
    };

    const scrollToHeading = (id: string, replace = false) => {
      const target = document.getElementById(id);
      if (!target) return;
      const anchorOffset = getAnchorOffset();
      const top = window.scrollY + target.getBoundingClientRect().top - anchorOffset;
      if (replace) {
        history.replaceState(null, '', encodedHash(id));
      } else {
        history.pushState(null, '', encodedHash(id));
      }
      window.scrollTo({ top, behavior: 'smooth' });
      setActive(id);
    };

    tocLinks.forEach((link) =>
      link.addEventListener('click', (event) => {
        const targetId = link.dataset.target;
        if (!targetId) return;
        event.preventDefault();
        scrollToHeading(targetId);
      }),
    );

    if (headings.length > 0) {
      applyScrollMargin();

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort(
              (a, b) => a.target.getBoundingClientRect().top - b.target.getBoundingClientRect().top,
            );

          if (visible[0]) {
            setActive(visible[0].target.id);
            return;
          }

          const above = entries
            .filter((entry) => entry.boundingClientRect.top < 0)
            .sort(
              (a, b) => b.target.getBoundingClientRect().top - a.target.getBoundingClientRect().top,
            );
          if (above[0]) setActive(above[0].target.id);
        },
        {
          rootMargin: `-${getAnchorOffset()}px 0% -55% 0%`,
          threshold: [0, 0.25, 0.5, 1],
        },
      );

      headings.forEach((heading) => observer.observe(heading));

      const hash = decodeHash(location.hash || '');
      if (hash) setActive(hash);

      window.addEventListener('hashchange', () => {
        const id = decodeHash(location.hash || '');
        setActive(id || null);
      });

      window.addEventListener('headerheightchange', applyScrollMargin);
      window.addEventListener('resize', applyScrollMargin);
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTocEnhancements, { once: true });
  } else {
    initTocEnhancements();
  }
</script>
