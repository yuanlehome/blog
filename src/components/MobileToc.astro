---
import TocTree from './TocTree.astro';
import { buildTocForest, type Heading } from '../lib/content/tocTree';

interface Props {
  headings: Heading[];
  /** Whether to render the built-in floating trigger button */
  showTrigger?: boolean;
}

// Build tree structure supporting multiple H1s
const tocForest = buildTocForest(Astro.props.headings);
if (tocForest.length === 0) {
  return null;
}

const showTrigger = Astro.props.showTrigger ?? false;
---

<>
  {
    showTrigger && (
      <button
        type="button"
        class="mobile-fab-pill fixed z-40 inline-flex touch-pan-y items-center gap-2 rounded-full border border-zinc-200 bg-neutral-50/92 px-4 text-sm font-medium text-zinc-900 shadow-lg backdrop-blur-sm transition hover:-translate-y-0.5 hover:border-sky-200 hover:text-sky-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 dark:border-zinc-800 dark:bg-zinc-900/88 dark:text-zinc-100 dark:hover:border-sky-500/50 dark:hover:text-sky-400 dark:focus-visible:ring-offset-zinc-900 lg:hidden"
        style="inset-inline-end: var(--mobile-edge-gap);"
        data-mobile-toc-open
        aria-haspopup="dialog"
        aria-expanded="false"
        aria-controls="mobile-toc-drawer"
      >
        📑 目录
      </button>
    )
  }

  <div
    class="fixed inset-0 z-50 pointer-events-none data-[open=true]:pointer-events-auto lg:hidden"
    data-mobile-toc
    data-open="false"
    aria-hidden="true"
  >
    <div
      class="absolute inset-0 bg-zinc-900/40 opacity-0 transition duration-200 data-[open=true]:opacity-100 dark:bg-black/50"
      data-mobile-toc-backdrop
    >
    </div>
    <div
      id="mobile-toc-drawer"
      role="dialog"
      aria-modal="true"
      aria-label="文章目录"
      class="mobile-drawer-panel absolute inset-x-0 bottom-0 translate-y-full rounded-t-[1.75rem] border border-zinc-200 bg-neutral-50/95 shadow-2xl ring-1 ring-black/5 transition duration-200 data-[open=true]:translate-y-0 dark:border-zinc-800 dark:bg-zinc-900/95 dark:ring-white/10"
      data-mobile-toc-drawer
    >
      <div class="mobile-drawer-handle bg-zinc-300/70 dark:bg-zinc-700/80"></div>
      <div class="mobile-drawer-header">
        <div>
          <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-50">文章目录</p>
          <p class="text-xs text-zinc-500 dark:text-zinc-400">点击条目可跳转</p>
        </div>
        <button
          type="button"
          class="mobile-drawer-close inline-flex items-center justify-center rounded-full border border-zinc-200 bg-neutral-50 text-sm font-medium text-zinc-800 shadow-sm transition hover:text-sky-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 dark:border-zinc-800 dark:bg-zinc-800 dark:text-zinc-100 dark:hover:text-sky-400 dark:focus-visible:ring-offset-zinc-900"
          data-mobile-toc-close
        >
          关闭
        </button>
      </div>
      <div class="mobile-drawer-scroll" data-mobile-toc-scroll>
        <ol class="space-y-3 text-sm">
          <TocTree nodes={tocForest} />
        </ol>
      </div>
    </div>
  </div>
</>

<script>
  import { createTouchClickGuard } from '../lib/ui/touchClickGuard';

  const tocRoot = document.querySelector('[data-mobile-toc]') as HTMLElement | null;
  const tocDrawer = document.querySelector('[data-mobile-toc-drawer]') as HTMLElement | null;
  const tocBackdrop = document.querySelector('[data-mobile-toc-backdrop]') as HTMLElement | null;
  const getTocOpenButtons = () =>
    Array.from(document.querySelectorAll('[data-mobile-toc-open]')) as HTMLButtonElement[];
  const tocCloseButton = document.querySelector(
    '[data-mobile-toc-close]',
  ) as HTMLButtonElement | null;
  const getTocLinks = () =>
    Array.from(
      (tocDrawer ?? tocRoot)?.querySelectorAll('[data-mobile-toc-link]') ?? [],
    ) as HTMLAnchorElement[];
  const body = document.body;
  const touchClickGuard = createTouchClickGuard();

  const getHeaderOffset = (): number => {
    const headerHeightStr = getComputedStyle(document.documentElement).getPropertyValue(
      '--site-header-height',
    );
    return parseFloat(headerHeightStr) || 0;
  };

  const getPageTopGap = (): number => {
    const pageGapStr = getComputedStyle(document.documentElement).getPropertyValue(
      '--page-space-top',
    );
    return parseFloat(pageGapStr) || 0;
  };

  const getStickyOffset = (): number => getHeaderOffset() + getPageTopGap();
  let scrollYBeforeLock = 0;

  // Delay to ensure drawer animation and scroll unlock complete before navigation
  const DRAWER_CLOSE_DELAY = 50;

  const emitToggle = (open: boolean) =>
    window.dispatchEvent(new CustomEvent('mobile-toc:toggle', { detail: { open } }));

  const setAriaExpanded = (open: boolean) => {
    getTocOpenButtons().forEach((button) =>
      button.setAttribute('aria-expanded', open ? 'true' : 'false'),
    );
  };

  const handleOpenTrigger = (event: Event) => {
    if (event instanceof MouseEvent && !touchClickGuard.shouldHandleClick(event)) {
      event.preventDefault();
      return;
    }
    event.preventDefault();
    setOpen(true);
  };

  const handleOpenPointerDown = (event: PointerEvent) => {
    touchClickGuard.handlePointerDown(event);
  };

  const handleOpenPointerMove = (event: PointerEvent) => {
    touchClickGuard.handlePointerMove(event);
  };

  const handleOpenPointerUp = (event: PointerEvent) => {
    touchClickGuard.handlePointerUp(event);
  };

  const handleOpenPointerCancel = (event: PointerEvent) => {
    touchClickGuard.handlePointerCancel(event);
  };

  const syncOpenButtons = () => {
    getTocOpenButtons().forEach((button) => {
      button.removeEventListener('pointerdown', handleOpenPointerDown);
      button.removeEventListener('click', handleOpenTrigger);
      button.addEventListener('pointerdown', handleOpenPointerDown, { passive: true });
      button.addEventListener('click', handleOpenTrigger);
      button.style.touchAction = 'pan-y';
    });
  };

  const lockScroll = () => {
    scrollYBeforeLock = window.scrollY;
    body.style.position = 'fixed';
    body.style.width = '100%';
    body.style.top = `-${scrollYBeforeLock}px`;
  };

  const unlockScroll = () => {
    body.style.position = '';
    body.style.width = '';
    body.style.top = '';
    window.scrollTo({ top: scrollYBeforeLock, behavior: 'instant' });
  };

  const setOpen = (open: boolean) => {
    if (!tocRoot || !tocDrawer) return;
    tocRoot.dataset.open = String(open);
    tocDrawer.dataset.open = String(open);
    tocBackdrop?.setAttribute('data-open', String(open));
    tocRoot.setAttribute('aria-hidden', open ? 'false' : 'true');
    setAriaExpanded(open);
    emitToggle(open);
    if (open) {
      lockScroll();
    } else {
      unlockScroll();
    }
  };

  const applyScrollMargin = () => {
    const stickyOffset = getStickyOffset();
    const headings = getTocLinks()
      .map((link) => document.getElementById(link.dataset.target || ''))
      .filter((el): el is HTMLElement => Boolean(el));
    headings.forEach((heading) => {
      heading.style.scrollMarginTop = `${stickyOffset + 16}px`;
    });
  };

  const encodedHash = (id: string) => `#${encodeURIComponent(id)}`;

  const scrollToHeading = (id: string, replace = false) => {
    const target = document.getElementById(id);
    if (!target) return;
    const stickyOffset = getStickyOffset();
    const top = window.scrollY + target.getBoundingClientRect().top - stickyOffset - 16;
    window.scrollTo({ top, behavior: 'instant' });
    if (replace) {
      history.replaceState(null, '', encodedHash(id));
    } else {
      history.pushState(null, '', encodedHash(id));
    }
  };

  syncOpenButtons();

  const openButtonObserver = new MutationObserver(syncOpenButtons);
  openButtonObserver.observe(document.body, {
    subtree: true,
    childList: true,
    attributes: true,
    attributeFilter: ['data-mobile-toc-open'],
  });

  window.addEventListener('pointermove', handleOpenPointerMove, { passive: true });
  window.addEventListener('pointerup', handleOpenPointerUp, { passive: true });
  window.addEventListener('pointercancel', handleOpenPointerCancel, { passive: true });

  tocCloseButton?.addEventListener('click', () => setOpen(false));
  tocBackdrop?.addEventListener('click', (event) => {
    if (event.target === tocBackdrop) setOpen(false);
  });

  const handleTocLinkClick = (event: Event) => {
    const link = event.currentTarget as HTMLAnchorElement | null;
    const targetId = link?.dataset.target;
    if (!targetId) return;
    event.preventDefault();
    event.stopPropagation();
    setOpen(false);
    // Wait for drawer to close and scroll unlock
    setTimeout(() => scrollToHeading(targetId), DRAWER_CLOSE_DELAY);
  };

  getTocLinks().forEach((link) => {
    link.removeEventListener('click', handleTocLinkClick);
    link.addEventListener('click', handleTocLinkClick);
  });

  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') setOpen(false);
  });

  applyScrollMargin();
  window.addEventListener('headerheightchange', applyScrollMargin);
</script>
